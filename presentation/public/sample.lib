                        "0.088, 0.090, 0.093, 0.098, 0.108, 0.128, 0.168" \
                    );
                }
            }
        }
    }

    /* Inverter - Drive strength 2 */
    cell (INVD2) {
        area : 1.5;
        cell_leakage_power : 0.015;
        
        pin (A) {
            direction : input;
            capacitance : 0.0015;
        }
        
